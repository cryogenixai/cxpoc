# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Pytest / tooling
.pytest_cache/
.coverage

# Local artifact store (job outputs)
_jobs/
*.local

# Eval scratch — mined feature tables, shortlists, scorecards, mining store
# (all regenerable from the corpus + frozen gold manifest)
eval/out/

# Gold-set page renders are a cache (regenerable from page.pdf); the frozen
# units (page.pdf, textlayer.json), manifest, and assembled PDF ARE committed.
gold/**/page.png

# Models (never committed; pulled to a volume on the VM)
models/
/models/

# AWS credentials — must NEVER be committed
aws/
*accessKeys*.csv
*.pem
credentials

# OS / editor
.DS_Store
.idea/
.vscode/
